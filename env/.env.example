API_PORT=8080
API_INTERNAL_PORT=8080
POSTGRES_PORT=5432

APP.MODE="dev"

EXTERNAL.FRONTEND_URL="https://yourfrontend.com/"

STORAGE.TYPE = minio
STORAGE.S3.ENDPOINT= "host.docker.internal:9000"
STORAGE.S3.PUBLIC_URL="http://localhost:9000"   
STORAGE.S3.REGION="ap-southeast-1"
STORAGE.S3.ACCESS_KEY="your-access-key"
STORAGE.S3.SECRET_KEY= "your-secret-key"
STORAGE.S3.BUCKET= "go-gin-starter"
STORAGE.S3.SSL=false
STORAGE.S3.USE_PATH_STYLE= true

SWAGGER.TITLE="Go gin starter template"
SWAGGER.DESCRIPTION="Api starter template for lazy people"
SWAGGER.VERSION="1.0"
SWAGGER.HOST="localhost:8080"
SWAGGER.BASE_PATH="/docs"

DATABASE.TIMEOUT=30s
DATABASE.POSTGRES.HOST=postgres
DATABASE.POSTGRES.PORT=5432
DATABASE.POSTGRES.NAME=go-gin-starter
DATABASE.POSTGRES.USERNAME=postgres
DATABASE.POSTGRES.PASSWORD=password
DATABASE.TIMEOUT=30s

DATABASE.REDIS.IS_ENABLED="true"
DATABASE.REDIS.HOST=redis
DATABASE.REDIS.PORT=6379
DATABASE.REDIS.PASSWORD=

JWT.SECRET_KEY.ACCESS="your_access_token_secret_here"
JWT.SECRET_KEY.REFRESH="your_refresh_token_secret_here"
JWT.TOKEN.ACCESS_LIFE_TIME="24h"

MAIL.FROM="youremail@gmail.com"
MAIL.FROM_NAME="Yourname"
MAIL.SMTP.HOST="smtp.gmail.com"
MAIL.SMTP.PORT=465
MAIL.SMTP.USER="youremail@gmail.com"
MAIL.SMTP.PASSWORD="yourpassword"